{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "/tmp/": "allow",
      "/tmp/*": "allow",
    },
    "websearch": "allow"
  },
  "provider": {
    "nvidia": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 600000
      }
    }
  }
}
